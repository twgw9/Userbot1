def email_blast_logic(target_id, count, gap):
    sent_count = 0
    try:
        with smtplib.SMTP_SSL('smtp.gmail.com', 465) as server:
            server.login(CFG["EMAIL"], CFG["PASS"])
            for i in range(count):
                template = random.choice(ABUSE_TEMPLATES).format(target=target_id)
                subject, body = template.split('\n\n', 1)
                
                msg = MIMEText(body)
                msg['Subject'] = subject.replace('Subject: ', '')
                msg['From'] = CFG["EMAIL"]
                msg['To'] = "abuse@telegram.org"
                
                server.sendmail(CFG["EMAIL"], "abuse@telegram.org", msg.as_string())
                sent_count += 1
                asyncio.run(asyncio.sleep(gap)) # Gap between emails
    except Exception as e:
        print(f"Login/SMTP Error: {e}")
    return sent_count

